# Contextual Proxy — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env (it is already in .gitignore).

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Mapbox public token (pk.*) — used for geocoding, reverse geocoding, and routing.
# Get one free at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# Optional (sensible defaults shown)
# ---------------------------------------------------------------------------

# CORS allowlist. Comma-separated origins, or "*" for development.
# In production, list your mobile app origins explicitly and never use *.
# CORS_ORIGINS=https://contextual.example.com,https://admin.contextual.example.com
CORS_ORIGINS=*

# Redis connection URL. Use rediss:// for TLS in production.
# Redis is used for rate-limiting counters and response caching.
REDIS_URL=redis://localhost:6379/0

# When true, Redis URL MUST use rediss:// (TLS). Set to true in production.
REQUIRE_REDIS_TLS=false

# Per-IP rate limit (requests per minute). Tune based on your traffic.
RATE_LIMIT_PER_MINUTE=60

# Cache TTL for Mapbox responses (seconds). 86400 = 24 hours.
MAX_CACHE_SECONDS=86400

# Proxy API key. When set, all requests must include x-api-key header matching this value.
# Leave empty for development (no key required).
# In production, generate a strong random string and share it with mobile app builds.
PROXY_API_KEY=
